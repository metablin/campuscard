# ID приложения VK ID (из кабинета id.vk.com). Пусто — кнопка VK ID скрыта.
VITE_VK_APP_ID=

# Куда VK ID вернёт пользователя после входа.
# Важно: VK ID локально работает только на порту 80 (http://localhost без порта).
VITE_VK_REDIRECT_URI=http://localhost/auth/callback

# Показывать кнопку dev-входа (true/false). Для продакшена — false.
VITE_DEV_AUTH=true
