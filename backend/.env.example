# База данных (SQLite-файл в backend/)
DATABASE_URL=sqlite:///./campuscard.db

# JWT-сессия (httpOnly-кука campuscard_session)
JWT_SECRET=замените-на-случайную-строку
JWT_EXPIRE_DAYS=7

# Dev-логин (POST /api/auth/dev) — только для локальной разработки
DEV_AUTH=true

# Куки: secure=true только при https (ngrok), для localhost — false
COOKIE_SECURE=false

# VK ID (боевой провайдер, OAuth 2.1 + PKCE)
VK_CLIENT_ID=
# Сервисный ключ доступа приложения; передаётся в VK ID параметром service_token
VK_CLIENT_SECRET=
# Должен совпадать с "Доверенный redirect URL" в кабинете id.vk.com
# (для локальной проверки VK ID — порт 80, без порта в URL)
VK_REDIRECT_URI=http://localhost

# Ориджин фронтенда для CORS
FRONTEND_ORIGIN=http://localhost:5173
