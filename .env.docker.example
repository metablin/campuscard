# Переменные для docker compose (корень репозитория).
# Скопируй в .env рядом с docker-compose.yml или экспортируй в shell.
# ВНИМАНИЕ: этот файл — только образец, реальные секреты не коммитить.

# Секрет подписи JWT-сессий (обязательно поменять в проде)
JWT_SECRET=замените-на-случайную-строку

# Dev-логин (POST /api/auth/dev) и кнопка dev-входа на фронтенде.
# true — для локальной проверки, false — для продакшена.
DEV_AUTH=true

# Secure-флаг сессионной куки: true только при HTTPS (за прокси с TLS)
COOKIE_SECURE=false

# VK ID (боевой провайдер). Пусто — кнопка VK ID скрыта.
VK_CLIENT_ID=
VK_CLIENT_SECRET=
